.dish-card {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}
.dish-card.compact {
  padding: 12rpx 0;
}
.dish-img {
  width: 180rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: #f0f0f0;
}
.dish-card.compact .dish-img {
  width: 120rpx;
  height: 100rpx;
}
.dish-info { flex: 1; margin-left: 20rpx; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
.dish-name { font-size: var(--font-md); font-weight: 600; }
.dish-desc { font-size: var(--font-xs); color: var(--text-hint); margin-top: 4rpx; }
.dish-bottom { display: flex; align-items: center; justify-content: space-between; }
.dish-price-wrap { color: var(--primary); font-weight: 700; font-size: var(--font-md); }
.dish-price-wrap .unit { font-size: var(--font-xs); font-weight: 400; color: var(--text-hint); }

.stepper { display: flex; align-items: center; }
.stepper-btn {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; font-weight: 600; transition: all 0.15s;
}
.stepper-btn.minus { background: #fff; border: 2rpx solid var(--primary); color: var(--primary); }
.stepper-btn.plus { background: var(--primary); color: #fff; border: 2rpx solid var(--primary); }
.stepper-btn.hidden { opacity: 0; pointer-events: none; width: 0; border: none; overflow: hidden; }
.stepper-num { width: 48rpx; text-align: center; font-size: var(--font-md); font-weight: 600; }
.stepper-num.hidden { opacity: 0; width: 0; overflow: hidden; }

.sold-out-mask {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.7);
  display: flex; align-items: center; justify-content: center;
}
.sold-out-mask text {
  background: rgba(0,0,0,0.5); color: #fff;
  padding: 8rpx 24rpx; border-radius: 20rpx; font-size: var(--font-sm);
}
