.page {
  min-height: 100vh;
  padding: 120rpx 40rpx 0;
  background: #fff;
}
.success-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--success);
  color: #fff;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  animation: popIn 0.4s ease;
}
@keyframes popIn {
  0% { transform: scale(0); }
  60% { transform: scale(1.1); }
  100% { transform: scale(1); }
}
.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--success);
  margin-bottom: 24rpx;
}
.success-no {
  font-size: var(--font-md);
  color: var(--text-secondary);
  background: #f5f5f5;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}
.success-tip {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-bottom: 60rpx;
}
.success-actions {
  width: 100%;
}
.btn-block {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: var(--font-md);
  font-weight: 600;
  border: none;
  margin-bottom: 20rpx;
}
.btn-block::after {
  border: none;
}
.btn-primary {
  background: var(--primary);
  color: #fff;
}
.btn-outline {
  background: #fff;
  color: var(--primary);
  border: 2rpx solid var(--primary) !important;
}
