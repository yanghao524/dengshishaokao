<!-- 订单确认页 -->
<view class="page">
  <!-- 顾客信息 -->
  <view class="card">
    <view class="card-title">联系信息</view>
    <view class="form-item">
      <view class="form-label">称呼</view>
      <input class="form-input" placeholder="请输入称呼" value="{{form.nickname}}" data-field="nickname" bindinput="onInput" maxlength="20"/>
    </view>
    <view class="form-item required">
      <view class="form-label">手机号</view>
      <input class="form-input" placeholder="请输入手机号" type="number" maxlength="11" value="{{form.phone}}" data-field="phone" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <view class="form-label">地址/桌号</view>
      <input class="form-input" placeholder="如：3号桌" value="{{form.address}}" data-field="address" bindinput="onInput" maxlength="50"/>
    </view>
  </view>

  <!-- 订单菜品 -->
  <view class="card">
    <view class="card-title">菜品明细</view>
    <view class="order-items">
      <view class="order-item" wx:for="{{cartSummary.items}}" wx:key="dishId">
        <image class="oi-img" src="{{item.image || '/images/dish-placeholder.png'}}" mode="aspectFill"></image>
        <view class="oi-info">
          <view class="oi-name ellipsis">{{item.name}}</view>
          <view class="oi-price"><text class="price">{{item.price}}</text></view>
        </view>
        <view class="oi-qty">x{{item.quantity}}</view>
        <view class="oi-subtotal"><text class="price">{{item.price * item.quantity}}</text></view>
      </view>
    </view>
    <view class="order-total">
      <text>共{{cartSummary.totalQuantity}}件，合计</text>
      <text class="price-large">{{cartSummary.totalPrice}}</text>
    </view>
  </view>

  <!-- 备注 -->
  <view class="card">
    <view class="card-title">备注</view>
    <textarea class="remark-input" placeholder="如有特殊要求请在此备注..." value="{{remark}}" bindinput="onRemarkInput" maxlength="200" auto-height/>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-area">
    <button class="btn-submit-order" bindtap="submitOrder" loading="{{submitting}}" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交订单'}}
    </button>
  </view>
</view>
