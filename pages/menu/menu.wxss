/* 菜单页样式 */
.menu-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* 主体区域 */
.menu-body {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* 左侧分类 */
.category-side {
  width: 180rpx;
  background: #f8f8f8;
  flex-shrink: 0;
}
.cat-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  padding: 0 12rpx;
  transition: background 0.2s;
}
.cat-item.active {
  background: #fff;
}
.cat-name {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
}
.cat-item.active .cat-name {
  color: var(--primary);
  font-weight: 700;
}
.cat-count {
  font-size: 18rpx;
  color: var(--text-hint);
  margin-top: 2rpx;
}
.cat-indicator {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  background: var(--primary);
  border-radius: 0 3rpx 3rpx 0;
}

/* 右侧菜品 */
.dish-scroll {
  flex: 1;
  background: #fff;
  padding: 0 20rpx;
}
.cat-header {
  font-size: 30rpx;
  font-weight: 700;
  padding: 24rpx 0 16rpx;
  color: var(--text-primary);
}
.dish-card {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.dish-card:last-child {
  border-bottom: none;
}
.dish-img {
  width: 180rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: #f0f0f0;
}
.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-left: 20rpx;
  justify-content: space-between;
}
.dish-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}
.dish-desc {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-top: 4rpx;
}
.dish-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.dish-price-wrap {
  color: var(--primary);
  font-weight: 700;
  font-size: var(--font-md);
}
.dish-price-wrap .unit {
  font-size: var(--font-xs);
  font-weight: 400;
  color: var(--text-hint);
}

/* 加减按钮 */
.stepper {
  display: flex;
  align-items: center;
  gap: 0;
}
.stepper-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.15s;
}
.stepper-btn.minus {
  background: #fff;
  border: 2rpx solid var(--primary);
  color: var(--primary);
}
.stepper-btn.plus {
  background: var(--primary);
  color: #fff;
  border: 2rpx solid var(--primary);
}
.stepper-btn.hidden {
  opacity: 0;
  pointer-events: none;
  width: 0;
  border: none;
  overflow: hidden;
}
.stepper-num {
  width: 48rpx;
  text-align: center;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}
.stepper-num.hidden {
  opacity: 0;
  width: 0;
  overflow: hidden;
}

/* 空菜品 */
.empty-dishes {
  display: flex;
  justify-content: center;
  padding: 40rpx;
  color: var(--text-hint);
  font-size: var(--font-sm);
}

/* 底部提示 */
.scroll-bottom-hint {
  text-align: center;
  padding: 40rpx 0;
  font-size: var(--font-xs);
  color: var(--text-hint);
}

/* 底部购物车栏 */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background: #fff;
  padding: 0 24rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  z-index: 99;
}
.cart-bar-left {
  display: flex;
  align-items: center;
}
.cart-icon-wrap {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  background: var(--primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cart-icon {
  font-size: 36rpx;
}
.cart-badge {
  position: absolute;
  top: -4rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background: #FF4D4F;
  color: #fff;
  font-size: 18rpx;
  border-radius: 16rpx;
  padding: 0 6rpx;
}
.cart-summary {
  margin-left: 16rpx;
}
.cart-total .price {
  font-size: 32rpx;
  font-weight: 700;
}
.cart-items-count {
  font-size: var(--font-xs);
  color: var(--text-hint);
}
.cart-bar-btn {
  padding: 0 40rpx;
  height: 64rpx;
  line-height: 64rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 32rpx;
  font-size: var(--font-md);
  font-weight: 600;
}

/* 详情弹窗 */
.detail-popup {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 200;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s;
}
.detail-popup.show {
  pointer-events: auto;
  opacity: 1;
}
.detail-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
}
.detail-panel {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 70vh;
  overflow-y: auto;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}
.detail-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.3);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  z-index: 1;
}
.detail-img {
  width: 100%;
  height: 360rpx;
  background: #f0f0f0;
  border-radius: 32rpx 32rpx 0 0;
}
.detail-body {
  padding: 24rpx 32rpx;
}
.detail-name {
  font-size: 36rpx;
  font-weight: 700;
}
.detail-price-row {
  margin-top: 12rpx;
}
.detail-price-row .unit {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-left: 4rpx;
}
.detail-desc {
  margin-top: 16rpx;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}
.detail-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border);
}
.stepper.large .stepper-btn {
  width: 56rpx;
  height: 56rpx;
  font-size: 36rpx;
}
.stepper.large .stepper-num {
  width: 64rpx;
  font-size: 34rpx;
}
.btn-add-cart {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 48rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 36rpx;
  font-size: var(--font-md);
  font-weight: 600;
  border: none;
}
.btn-add-cart::after {
  border: none;
}
