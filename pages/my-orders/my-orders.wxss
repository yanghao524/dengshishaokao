/* 我的订单 */
.page {
  min-height: 100vh;
  background: var(--bg-page);
}
.tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: var(--font-md);
  color: var(--text-secondary);
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}
.tab.active {
  color: var(--primary);
  font-weight: 700;
  border-bottom-color: var(--primary);
}

/* 订单卡片 */
.order-card {
  background: #fff;
  margin: 20rpx;
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-shadow: var(--shadow);
}
.oc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.oc-no {
  font-size: var(--font-sm);
  color: var(--text-hint);
  font-weight: 500;
}
.oc-items {
  border-top: 1rpx solid #f5f5f5;
  border-bottom: 1rpx solid #f5f5f5;
  padding: 16rpx 0;
}
.oc-item {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}
.oci-img {
  width: 64rpx;
  height: 52rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}
.oci-name {
  flex: 1;
  margin-left: 12rpx;
  font-size: var(--font-sm);
  color: var(--text-primary);
}
.oci-qty {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-left: 12rpx;
}
.oc-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  font-size: var(--font-xs);
  color: var(--text-hint);
}
.oc-total {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}
.oc-total .price {
  font-size: var(--font-md);
  font-weight: 700;
  margin-left: 4rpx;
}
.oc-edited {
  margin-top: 12rpx;
  padding: 8rpx 16rpx;
  background: #FFF3EC;
  border-radius: 8rpx;
  font-size: var(--font-xs);
  color: #FF6B3D;
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 24rpx;
  font-size: var(--font-xs);
  color: var(--text-hint);
}
.go-menu-btn {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 40rpx;
  font-size: var(--font-md);
}
