<!-- 商家订单详情 -->
<view class="page">
  <view wx:if="{{loaded}}">
    <!-- 顾客信息卡片 -->
    <view class="card customer-card">
      <view class="card-title">顾客信息</view>
      <view class="customer-info">
        <view class="ci-row">
          <text class="ci-label">称呼</text>
          <text class="ci-value">{{order.customerNickname || '未填写'}}</text>
        </view>
        <view class="ci-row ci-phone">
          <text class="ci-label">手机号</text>
          <text class="ci-value ci-phone-value">{{order.customerPhone}}</text>
        </view>
        <view class="ci-row">
          <text class="ci-label">地址/桌号</text>
          <text class="ci-value">{{order.customerAddress || '未填写'}}</text>
        </view>
      </view>
      <view class="ci-actions">
        <button class="ci-btn ci-btn-call" bindtap="callCustomer">
          <text>📞 拨打电话</text>
        </button>
        <button class="ci-btn ci-btn-copy" bindtap="copyPhone">
          <text>📋 复制号码</text>
        </button>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="card">
      <view class="card-header">
        <view class="card-title">订单菜品 #{{order.orderNo}}</view>
        <view class="badge badge-{{order.status}}">
          {{order.status === 'pending' ? '待接单' : ''}}
          {{order.status === 'accepted' ? '已接单' : ''}}
          {{order.status === 'completed' ? '已完成' : ''}}
        </view>
      </view>

      <view class="edit-notice" wx:if="{{order.isEdited}}">
        ⚠ 此订单已由商家调整过
      </view>

      <!-- 菜品列表 -->
      <view class="item-table">
        <view class="it-header">
          <text class="it-th name">菜品</text>
          <text class="it-th price">单价</text>
          <text class="it-th qty">数量</text>
          <text class="it-th subtotal">小计</text>
        </view>
        <view class="it-row" wx:for="{{order.items}}" wx:key="dishId">
          <text class="it-td name ellipsis">{{item.name}}</text>
          <text class="it-td price"><text class="price">{{item.price}}</text></text>
          <text class="it-td qty">x{{item.quantity}}</text>
          <text class="it-td subtotal"><text class="price">{{item.subtotal}}</text></text>
        </view>
      </view>

      <view class="order-summary">
        <view class="os-row" wx:if="{{order.remark}}">
          <text class="os-label">备注</text>
          <text class="os-value">{{order.remark}}</text>
        </view>
        <view class="os-row os-total">
          <text class="os-label">合计 {{order.totalQuantity}} 件</text>
          <text class="price-large">{{order.totalPrice}}</text>
        </view>
        <view class="os-row">
          <text class="os-label">下单时间</text>
          <text class="os-value">{{order.createdAt}}</text>
        </view>
        <view class="os-row" wx:if="{{order.completedAt}}">
          <text class="os-label">完成时间</text>
          <text class="os-value">{{order.completedAt}}</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-area">
      <!-- 待接单 -->
      <block wx:if="{{order.status === 'pending'}}">
        <button class="act-btn act-accept" bindtap="acceptOrder">接单</button>
        <button class="act-btn act-edit" bindtap="editOrder">编辑订单</button>
      </block>

      <!-- 已接单 -->
      <block wx:if="{{order.status === 'accepted'}}">
        <button class="act-btn act-complete" bindtap="completeOrder">完成出餐</button>
        <button class="act-btn act-edit" bindtap="editOrder">编辑订单</button>
      </block>

      <!-- 已完成/已取消 - 无操作按钮 -->
    </view>
  </view>

  <view class="loading" wx:else>
    <text>加载中...</text>
  </view>
</view>
