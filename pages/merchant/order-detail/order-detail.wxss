/* 商家订单详情 */
.page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 200rpx;
}
.loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
  color: var(--text-hint);
}
.card {
  background: #fff;
  border-radius: var(--radius-md);
  margin: 20rpx;
  padding: 24rpx;
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 700;
}

/* 顾客信息 */
.customer-info {
  margin-bottom: 20rpx;
}
.ci-row {
  display: flex;
  padding: 12rpx 0;
  font-size: var(--font-md);
}
.ci-label {
  color: var(--text-hint);
  width: 160rpx;
  flex-shrink: 0;
}
.ci-value {
  color: var(--text-primary);
}
.ci-phone-value {
  font-weight: 700;
  letter-spacing: 2rpx;
  font-size: 32rpx;
}
.ci-actions {
  display: flex;
  gap: 16rpx;
}
.ci-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 36rpx;
  font-size: var(--font-sm);
  border: none;
  padding: 0;
}
.ci-btn::after { border: none; }
.ci-btn-call {
  background: #E8F4FD;
  color: #1890FF;
}
.ci-btn-copy {
  background: #F5F5F5;
  color: var(--text-secondary);
}

/* 编辑提示 */
.edit-notice {
  padding: 12rpx 16rpx;
  background: #FFF3EC;
  border-radius: 8rpx;
  font-size: var(--font-xs);
  color: #FF6B3D;
  margin-bottom: 16rpx;
}

/* 菜品表格 */
.item-table {
  margin-top: 8rpx;
}
.it-header {
  display: flex;
  padding: 8rpx 0;
  border-bottom: 2rpx solid var(--border);
}
.it-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.it-th, .it-td {
  font-size: var(--font-sm);
}
.it-th {
  color: var(--text-hint);
  font-weight: 500;
}
.name { flex: 2; }
.price { flex: 1; text-align: center; }
.qty { flex: 0.8; text-align: center; }
.subtotal { flex: 1; text-align: right; font-weight: 600; }
.it-td.price .price { font-weight: 600; }

/* 订单汇总 */
.order-summary {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}
.os-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  font-size: var(--font-sm);
}
.os-label { color: var(--text-hint); }
.os-value { color: var(--text-secondary); }
.os-total { margin-top: 8rpx; padding-top: 12rpx; border-top: 1rpx solid #f5f5f5; }

/* 操作按钮 */
.action-area {
  padding: 20rpx;
  display: flex;
  gap: 16rpx;
}
.act-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: var(--font-md);
  font-weight: 600;
  border: none;
}
.act-btn::after { border: none; }
.act-accept {
  background: var(--primary);
  color: #fff;
}
.act-complete {
  background: var(--success);
  color: #fff;
}
.act-edit {
  background: #f5f5f5;
  color: var(--text-primary);
}
