.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #D4380D 0%, #FF6B3D 100%);
  padding: 40rpx;
}
.login-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
}
.login-title {
  font-size: 40rpx;
  font-weight: 700;
  text-align: center;
  color: var(--text-primary);
}
.login-subtitle {
  font-size: var(--font-sm);
  text-align: center;
  color: var(--text-hint);
  margin-top: 8rpx;
  margin-bottom: 48rpx;
}
.form-group {
  margin-bottom: 32rpx;
}
.form-label {
  font-size: var(--font-md);
  font-weight: 600;
  margin-bottom: 12rpx;
}
.form-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: var(--font-md);
  box-sizing: border-box;
}
.form-input:focus {
  border-color: var(--primary);
}
.btn-login {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 44rpx;
  font-size: var(--font-md);
  font-weight: 700;
  border: none;
  margin-top: 20rpx;
}
.btn-login::after {
  border: none;
}
.btn-login[disabled] {
  opacity: 0.6;
}
