/* 编辑订单 */
.page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 160rpx;
}
.card {
  background: #fff;
  border-radius: var(--radius-md);
  margin: 20rpx;
  padding: 24rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

/* 编辑项 */
.edit-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.ei-info {
  flex: 1;
  min-width: 0;
}
.ei-name {
  font-size: var(--font-sm);
  font-weight: 500;
}
.ei-price {
  font-size: var(--font-xs);
  font-weight: 600;
  margin-top: 4rpx;
}
.ei-stepper {
  display: flex;
  align-items: center;
  margin: 0 16rpx;
}
.stepper-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}
.stepper-btn.minus {
  border: 2rpx solid var(--primary);
  color: var(--primary);
}
.stepper-btn.minus.disabled {
  border-color: #ddd;
  color: #ddd;
}
.stepper-btn.plus {
  background: var(--primary);
  color: #fff;
}
.stepper-num {
  width: 60rpx;
  text-align: center;
  font-size: var(--font-md);
  font-weight: 600;
}
.ei-del {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-hint);
}

/* 添加菜品 */
.add-dish-btn {
  padding: 20rpx;
  text-align: center;
  color: var(--primary);
  font-size: var(--font-md);
  font-weight: 500;
  border: 2rpx dashed var(--primary);
  border-radius: var(--radius-sm);
  margin-top: 20rpx;
}

/* 备注 */
.remark-group {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}
.remark-label {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-bottom: 8rpx;
}
.remark-input {
  width: 100%;
  min-height: 80rpx;
  font-size: var(--font-md);
}

/* 总计 */
.edit-total {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  flex-wrap: wrap;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  gap: 6rpx;
}

/* 保存 */
.save-area {
  padding: 20rpx;
}
.btn-save {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 44rpx;
  font-size: var(--font-md);
  font-weight: 700;
  border: none;
}
.btn-save::after { border: none; }

/* 菜品选择弹窗 */
.picker-popup {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 200;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s;
}
.picker-popup.show {
  pointer-events: auto;
  opacity: 1;
}
.picker-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
}
.picker-panel {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}
.picker-title { font-size: 32rpx; font-weight: 700; }
.picker-close { font-size: 28rpx; color: var(--text-hint); padding: 8rpx; }
.picker-list { flex: 1; overflow-y: auto; }
.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.pi-name { font-size: var(--font-md); font-weight: 500; max-width: 400rpx; }
.pi-price { font-size: var(--font-xs); color: var(--text-hint); margin-top: 4rpx; }
.pi-add {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: var(--primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
