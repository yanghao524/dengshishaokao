<!-- 菜品详情页 (独立页面版本) -->
<view class="page">
  <image class="detail-img" src="{{dish.image || '/images/dish-placeholder.png'}}" mode="aspectFill"></image>
  <view class="detail-body">
    <view class="detail-name">{{dish.name}}</view>
    <view class="detail-price-row">
      <text class="price-large">{{dish.price}}</text>
      <text class="unit">/{{dish.unit}}</text>
    </view>
    <view class="detail-desc" wx:if="{{dish.description}}">{{dish.description}}</view>
    <view class="detail-sold" wx:if="{{!dish.isAvailable}}">
      <text>已售罄</text>
    </view>
    <view class="detail-actions" wx:else>
      <view class="stepper-ctn">
        <view class="stepper-btn minus {{quantity <= 1 ? 'disabled' : ''}}" bindtap="decrease">
          <text>-</text>
        </view>
        <view class="stepper-num">{{quantity}}</view>
        <view class="stepper-btn plus" bindtap="increase">
          <text>+</text>
        </view>
      </view>
      <button class="btn-submit" bindtap="addToCart">加入购物车</button>
    </view>
  </view>
</view>
