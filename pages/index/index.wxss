/* 首页样式 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  position: relative;
  height: 500rpx;
  overflow: hidden;
}
.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #D4380D 0%, #FF6B3D 50%, #FF976A 100%);
}
.header-bg::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 60rpx;
  background: var(--bg-page);
  border-radius: 40rpx 40rpx 0 0;
}
.header-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 140rpx;
  z-index: 1;
}
.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.95);
  margin-bottom: 16rpx;
}
.brand-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
  letter-spacing: 4rpx;
}
.brand-desc {
  font-size: var(--font-sm);
  color: rgba(255,255,255,0.9);
  margin-top: 8rpx;
}

/* 推荐区域 */
.section {
  margin: 0 20rpx;
}
.section-title {
  display: flex;
  align-items: center;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}
.title-icon {
  margin-right: 8rpx;
}
.featured-scroll {
  white-space: nowrap;
}
.featured-list {
  display: inline-flex;
  gap: 16rpx;
}
.featured-item {
  display: inline-block;
  width: 240rpx;
  background: #fff;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow);
}
.featured-img {
  width: 240rpx;
  height: 180rpx;
  background: #f0f0f0;
}
.featured-info {
  padding: 16rpx;
}
.featured-name {
  font-size: var(--font-md);
  font-weight: 600;
  margin-bottom: 8rpx;
}
.featured-price {
  color: var(--primary);
  font-weight: 700;
  font-size: var(--font-md);
}
.featured-price .unit {
  font-size: var(--font-xs);
  font-weight: 400;
  color: var(--text-hint);
}

/* 操作区 */
.action-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
  padding: 0 20rpx;
}
.btn-start-order {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, #D4380D, #FF6B3D);
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(212, 56, 13, 0.35);
  border: none;
}
.btn-start-order::after {
  border: none;
}
.btn-icon {
  margin-right: 12rpx;
}
.action-links {
  display: flex;
  gap: 40rpx;
  margin-top: 24rpx;
}
.link-item {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.link-icon {
  margin-right: 6rpx;
}

/* 商家入口 */
.merchant-entry {
  display: flex;
  justify-content: center;
  margin-top: 32rpx;
  padding: 0 20rpx;
}
.merchant-card {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 80rpx;
  background: #fff;
  border-radius: 50rpx;
  border: 2rpx dashed #E8C4B0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.merchant-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}
.merchant-text {
  font-size: var(--font-sm);
  color: #B8603E;
  font-weight: 500;
}
.merchant-arrow {
  font-size: var(--font-sm);
  color: #CC9A80;
  margin-left: 8rpx;
}

/* 页脚 */
.footer {
  text-align: center;
  margin-top: 60rpx;
  padding: 20rpx;
}
.footer navigator {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

/* 隐私弹窗 */
.privacy-popup {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999;
}
.privacy-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
}
.privacy-dialog {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}
.privacy-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  text-align: center;
}
.privacy-content {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 32rpx;
}
.privacy-link {
  color: var(--primary);
  display: inline;
}
.privacy-btns {
  display: flex;
  gap: 20rpx;
}
.privacy-btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: var(--font-md);
  border: none;
}
.privacy-btn-agree {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: var(--primary);
  color: #fff;
  border-radius: 40rpx;
  font-size: var(--font-md);
  border: none;
}

/* 授权弹窗 */
.auth-popup {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9998;
}
.auth-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
}
.auth-dialog {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
}
.auth-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
}
.auth-title-icon {
  margin-right: 8rpx;
  font-size: 36rpx;
}
.auth-subtitle {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-bottom: 36rpx;
}

/* 头像区域 */
.auth-avatar-area {
  margin-bottom: 32rpx;
}
.auth-avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: 4rpx dashed #E8C4B0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: visible;
  line-height: 1;
}
.auth-avatar-btn::after {
  border: none;
}
.auth-avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: #FFF1E8;
}
.auth-avatar-tip {
  font-size: var(--font-xs);
  color: #B8603E;
  margin-top: 16rpx;
  white-space: nowrap;
}

/* 昵称区域 */
.auth-nickname-area {
  width: 100%;
  margin-bottom: 36rpx;
}
.auth-nickname-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}
.auth-nickname-input {
  width: 100%;
  height: 80rpx;
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: var(--font-md);
  box-sizing: border-box;
}

/* 授权按钮 */
.auth-btns {
  display: flex;
  gap: 20rpx;
  width: 100%;
}
.auth-btn-skip {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #f5f5f5;
  color: var(--text-secondary);
  border-radius: 40rpx;
  font-size: var(--font-md);
  border: none;
}
.auth-btn-skip::after {
  border: none;
}
.auth-btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #D4380D, #FF6B3D);
  color: #fff;
  border-radius: 40rpx;
  font-size: var(--font-md);
  font-weight: 600;
  border: none;
}
.auth-btn-confirm::after {
  border: none;
}

.loading-row {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}
.loading-text {
  color: var(--text-hint);
  font-size: var(--font-sm);
}
