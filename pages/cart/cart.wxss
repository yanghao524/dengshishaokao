/* 购物车 */
.page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 160rpx;
}

/* 空状态 */
.go-menu-btn {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 40rpx;
  font-size: var(--font-md);
}

/* 购物车列表 */
.cart-list {
  background: #fff;
  margin: 20rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}
.cart-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}
.cart-item:last-child {
  border-bottom: none;
}
.cart-item-img {
  width: 120rpx;
  height: 100rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: #f0f0f0;
}
.cart-item-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}
.cart-item-name {
  font-size: var(--font-md);
  font-weight: 500;
}
.cart-item-price {
  margin-top: 8rpx;
  font-weight: 600;
}
.cart-item-stepper {
  display: flex;
  align-items: center;
  gap: 0;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.stepper-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}
.stepper-btn.minus {
  background: #fff;
  border: 2rpx solid var(--primary);
  color: var(--primary);
}
.stepper-btn.minus.disabled {
  border-color: #ddd;
  color: #ddd;
}
.stepper-btn.plus {
  background: var(--primary);
  color: #fff;
  border: 2rpx solid var(--primary);
}
.stepper-num {
  width: 56rpx;
  text-align: center;
  font-size: var(--font-md);
  font-weight: 600;
}
.cart-item-del {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

/* 底部结算栏 */
.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background: #fff;
  padding: 0 24rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  z-index: 99;
}
.cart-footer-left {
  display: flex;
  align-items: baseline;
}
.cart-footer-label {
  font-size: var(--font-md);
  color: var(--text-primary);
}
.btn-submit {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 40rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 36rpx;
  font-size: var(--font-md);
  font-weight: 600;
  border: none;
}
.btn-submit::after {
  border: none;
}
